[tasks.sync-mise-env-user]
description = "Persist mise environment variables into user-level Windows env vars"
hide = true
shell = 'powershell -Command'
run = '''
$miseEnv = mise env --json | ConvertFrom-Json

if ($null -eq $miseEnv) {
  throw "Unable to parse output from 'mise env --json'."
}

$updated = 0
foreach ($property in $miseEnv.PSObject.Properties) {
  $name = [string]$property.Name

  if ($name -ieq "PATH") {
    continue
  }

  $value = [string]$property.Value
  [Environment]::SetEnvironmentVariable($name, $value, [EnvironmentVariableTarget]::User)
  Set-Item -Path "Env:$name" -Value $value
  $updated++
}

Write-Host "Updated $updated user environment variable(s) from mise env (excluding PATH)."
'''
{{ end }}

