[tasks.build-windows-powershell-autoload]
description = 'Run the command and store the content in the Windows PowerShell autoload path'
hide = true
usage = '''
arg "<command>" help = "The command that produces an output"
arg "<filename>" help = "The filename where to write the command output"
'''
shell = 'powershell -Command'
run = '''
$autoloadDir = Join-Path $HOME "Documents\WindowsPowerShell\autoload"

$content = & ([ScriptBlock]::Create('{{ "{{" }} usage.command {{ "}}" }}'))
if ($content -is [System.Array]) {
  $content = $content -join "`n"
}

New-Item -ItemType Directory -Force -Path $autoloadDir | Out-Null
$target = Join-Path $autoloadDir "{{ "{{" }} usage.filename {{ "}}" }}"
$content = [string]$content

if (Test-Path -LiteralPath $target) {
  try {
    $existing = [System.IO.File]::ReadAllText($target)
    if ($existing -eq $content) {
      return
    }
  } catch {
    # Ignore read failures and continue with write retries.
  }
}

$maxAttempts = 20
for ($attempt = 1; $attempt -le $maxAttempts; $attempt++) {
  try {
    [System.IO.File]::WriteAllText($target, $content, [System.Text.UTF8Encoding]::new($false))
    return
  } catch [System.IO.IOException] {
    if ($attempt -eq $maxAttempts) {
      throw "Unable to write '$target' after $maxAttempts attempts because the file is in use. Close Windows PowerShell sessions using this file and retry."
    }
    Start-Sleep -Milliseconds 250
  }
}
'''

