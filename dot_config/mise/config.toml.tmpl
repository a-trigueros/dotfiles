[settings]
experimental = true
env_shell_expand = true

[tools]
argocd = "latest"
atuin = "latest"
bat = "latest"
caddy = "latest"
carapace = "latest"
deno = "latest"
docker-cli = { version = "latest", os = ["macos", "linux"] }
dotnet = "latest"
eza = "latest"
{{- if eq .chezmoi.os "darwin" }}
fnox = "latest"
{{- end }}
fzf = "latest"
helm = "latest"
hugo = "latest"
java = "latest"
jj = "latest"
jjui = "latest"
kubectl = "latest"
lazydocker = "latest"
lazygit = "latest"
lazyjournal = { version = "latest", os = ["macos", "linux"] }
lazyssh = "latest"
mas = { version = "latest", os = "macos" }
neovim = "latest"
node = "lts"
opencode = "latest"
pnpm = "latest"
{{- if eq .chezmoi.os "windows" }}
powershell-core = "latest"
{{- end }}
python = "latest"
ripgrep = "latest"
rust = "latest"
sqlite = "latest"
starship = "latest"
tlrc = "latest"
tmux = "latest"
tree-sitter = "latest"
uv = "latest"
yazi = "latest"
yt-dlp = "latest"
zellij = { version = "latest", os = ["macos", "linux"] }
zoxide = "latest"
"aqua:sharkdp/fd" = "latest"
"cargo:sheldon" = { version = "latest", os = ["macos", "linux"] }
"github:murex/TCR" = "latest"
"github:nushell/nushell" = "latest"
"github:remotemobprogramming/mob" = { version = "latest", os = [
  "macos",
  "linux",
]}
"github:rtk-ai/rtk" = { version = "latest", os = [
  "macos",
  "linux",
]}

[env]
EDITOR = "nvim"
VISUAL = "nvim"
PAGER = "less -RFX"
BAT_THEME = "Catppuccin Macchiato"
BAT_STYLE = "numbers,changes,header,grid"
BAT_PAGER = "less -RF"
MANPAGER = "sh -c 'col -bx | bat -l man -p'"
MANROFFOPT = "-c"
EZA_COLORS = "da=38;5;245:sn=38;5;28:sb=38;5;28:ur=38;5;40:uw=38;5;40:ux=38;5;40:ue=38;5;40:gr=38;5;226:gw=38;5;226:gx=38;5;226:tr=38;5;196:tw=38;5;196:tx=38;5;196"
EZA_ICON_SPACING = "2"
{{ if eq .chezmoi.os "darwin" }}
DOCKER_HOST = 'unix:///Users/$USER/.local/share/containers/podman/machine/podman.sock'
SSH_AUTH_SOCK = '~/Library/Group\ Containers/2BUA8C4S2C.com.1password/t/agent.sock'

_.path = [
  "/opt/homebrew/bin",
  "/opt/homebrew/sbin",
  "/Applications/Visual Studio Code.app/Contents/Resources/app/bin",
]
{{ end }}

[shell_alias]
als = 'atuin script list'
asr = 'atuin script run'
ls = 'eza --color=always --icons=always'
ll = 'eza -lbF --git --icons=always --color=always'
la = 'eza -lbhHigUmuSa --time-style=long-iso --git --color-scale --icons=always --color=always'
lt = 'eza --tree --level=2 --icons=always --color=always'
ltt = 'eza --tree --level=3 --icons=always --color=always'
lttt = 'eza --tree --level=4 --icons=always --color=always'
lg = 'eza -lbhHigUmuSa@ --git --color=always --icons=always'
lm = 'eza -lbhHigUmuSa --sort=modified --color=always --icons=always'
lz = 'eza -lbhHigUmuSa --sort=size --color=always --icons=always'
cd = 'z'
".." = 'cd ..'
"..." = 'cd ../..'
"...." = 'cd ../../..'

[hooks]
postinstall = [
  { task = "build-all-nushell-autoloads" }
]
{{ if eq .chezmoi.os "darwin" }}
preinstall = "export GITHUB_TOKEN=$(fnox get GITHUB_TOKEN)"

[tasks.install-gui]
description = "Install GUI apps"
run = '''
brew bundle install --file="~/.config/packages/darwin/gui.brew"
brew services start sketchybar
'''

[tasks.install-gaming]
description = "Install Gaming apps"
run = '''
brew bundle install --file="~/.config/packages/darwin/gaming.brew"
'''

[tasks.update-homebrew]
description = "Install homebrew apps"
usage = '''
flag "-g --greedy" help="Also include casks with auto_updates true or version :latest."
'''
run = '''
brew update 
brew upgrade {% if usage.greedy %} -g {% endif %}
'''

[tasks.update-mas]
description = "Update AppStore applications"
run = '''
mas upgrade
'''
{{ end }}

[tasks.build-nushell-autoload]
description = 'Run the command and store the content in the filename in the nushell autoload path'
hide = true
usage = '''
arg "<command>" help = "The command that produces an output"
arg "<filename>" help = "The filename where to write the command output"
'''
{{ if eq .chezmoi.os "windows" }}
shell = 'powershell -Command'
run = '''
New-Item -ItemType Directory -Path "$env:APPDATA\nushell\autoload" -Force | Out-Null
if (Get-Command nu -ErrorAction SilentlyContinue) {
  nu -c '{{ "{{" }} usage.command {{ "}}" }} | save -f  ($nu.user-autoload-dirs | first | path join "{{ "{{" }} usage.filename {{ "}}" }}")'
} '''
{{ else }}
run = '''
mkdir -p "$HOME/Library/Application Support/nushell/autoload/"
if command -v nu >/dev/null 2>&1; then
  nu -c '{{ "{{" }} usage.command {{ "}}" }} | save -f  ($nu.user-autoload-dirs | first | path join "{{ "{{" }} usage.filename {{ "}}" }}")'
fi
'''
{{ end }}


[tasks.build-all-nushell-autoloads]
description = "Used to build nushell autoload files"
depends = [
  { task = "build-nushell-autoload", args = ["atuin init nu", "atuin.nu"] },
  { task = "build-nushell-autoload", args = ["carapace _carapace nushell", "carapace.nu"] },
  { task = "build-nushell-autoload", args = ["mise activate nu", "mise.nu"] },
  { task = "build-nushell-autoload", args = ["starship init nu", "starship.nu"] },
  { task = "build-nushell-autoload", args = ["zoxide init nushell", "zoxide.nu"] },
]
run = ":"
run_windows = "rem noop"

{{ if eq .chezmoi.os "windows" }}

[tasks.set-autologin]
description = "Login automatically as a given user"
hide = true
shell = 'powershell -Command'
usage = '''
arg "<password>" help = "The password of the user"
'''
run = '''
Write-Host "Setting autologin"
$currentUser = $env:USERNAME
reg add "HKLM\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Winlogon" /v "AutoAdminLogon" /t REG_SZ /d "1" /f
reg add "HKLM\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Winlogon" /v "DefaultUserName" /t REG_SZ /d "$currentUser" /f
reg add "HKLM\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Winlogon" /v "DefaultPassword" /t REG_SZ /d "{{ "{{" }} usage.password {{ "}}" }}" /f

Clear-History
Remove-Item (Get-PSReadLineOption).HistorySavePath -Force
'''

[tasks.disable-lockscreen]
description = "Disabling lock screen"
hide = true
shell = 'powershell -Command'
run = '''
Write-Host "Disabling lock screen"
powercfg /change monitor-timeout-ac 0
powercfg /change monitor-timeout-dc 0
powercfg /change standby-timeout-ac 0
powercfg /change standby-timeout-dc 0

reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows\Personalization" /v "NoLockScreen" /t REG_SZ /d "1" /f
'''

[tasks.enable-ssh]
description = 'Allow me to signin using my private key'
shell = 'powershell -Command'
run = '''
Write-Host "Setting up ssh"
$PUBLIC_KEYS_SOURCE = Join-Path "{{ .chezmoi.sourceDir }}" "ssh\public_keys"
$SSH_COMPUTER_DIR = "C:\ProgramData\ssh"
$SSHD_CONFIG_PATH = "C:\ProgramData\ssh\sshd_config"

function Set-SSHDConfigLine
{
  <#
    .SYNOPSIS
        Updates or adds a configuration line in the SSH daemon config
    .PARAMETER Config
        The configuration content array
    .PARAMETER Key
        The configuration key to set
    .PARAMETER Value
        The value to assign to the key
    #>
  param(
    [Parameter(Mandatory)]
    [Object[]]$Config,
        
    [Parameter(Mandatory)]
    [string]$Key,
        
    [Parameter(Mandatory)]
    [string]$Value
  )
    
  $pattern = "^\s*#?\s*$Key\s+.*$"
    
  if ($Config -match $pattern)
  {
    return $Config -replace $pattern, "$Key $Value"
  } else
  {
    return $Config + "$Key $Value"
  }
}

# Install sshd
Add-WindowsCapability -Online -Name OpenSSH.Server -ErrorAction Stop

# Open port 22
if (-not (Get-NetFirewallRule -Name 'sshd' -ErrorAction SilentlyContinue)) {
  New-NetFirewallRule `
    -Name 'sshd' `
    -DisplayName 'OpenSSH Server (sshd)' `
    -Enabled True `
    -Direction Inbound `
    -Protocol TCP `
    -Action Allow `
    -LocalPort 22 | Out-Null
}

# Create new basic sshd config file
Remove-Item -LiteralPath $SSHD_CONFIG_PATH -Force -ErrorAction SilentlyContinue
Start-Service sshd -ErrorAction SilentlyContinue
Start-Sleep -Seconds 2
Stop-Service sshd -ErrorAction SilentlyContinue

# Fine tune ssh configuration
$config = Get-Content -LiteralPath $SSHD_CONFIG_PATH -ErrorAction Stop

# Disable password authentication, enable key-based only
$config = Set-SSHDConfigLine -Config $config -Key "PasswordAuthentication" -Value "no"
$config = Set-SSHDConfigLine -Config $config -Key "ChallengeResponseAuthentication" -Value "no"
$config = Set-SSHDConfigLine -Config $config -Key "PubkeyAuthentication" -Value "yes"
$config = Set-SSHDConfigLine -Config $config -Key "AuthorizedKeysFile" -Value ".ssh/authorized_keys"
  
# Configure keepalive to prevent disconnections
$config = Set-SSHDConfigLine -Config $config -Key "ClientAliveInterval" -Value "60"
$config = Set-SSHDConfigLine -Config $config -Key "ClientAliveCountMax" -Value "3"
$config = Set-SSHDConfigLine -Config $config -Key "TCPKeepAlive" -Value "yes"
  
$config | Set-Content -Encoding ascii -LiteralPath $SSHD_CONFIG_PATH

# Install ssh public key

$userSshDir = Join-Path $env:USERPROFILE ".ssh"
New-Item -ItemType Directory -Path $userSshDir -Force | Out-Null

$userAuthorizedKeysPath = Join-Path $userSshDir "authorized_keys"
Copy-Item $PUBLIC_KEYS_SOURCE $userAuthorizedKeysPath -Force

# Install admin ssh key
$adminKeysPath = Join-Path $SSH_COMPUTER_DIR "administrators_authorized_keys"
Copy-Item $PUBLIC_KEYS_SOURCE $adminKeysPath -Force

# Configure ssh service as automatic
Set-Service -Name sshd -StartupType 'Automatic'

Write-Host "Finished configuring ssh (restart required to apply changes)"
'''

[tasks.remove-bloatware]
description = 'Uninstall windows embedded bloatware'
shell = 'powershell -Command'
run = '''
Write-Host "Uninstalling bloatware"
$toCleanFilter = @(
    'Microsoft.Paint',
    'Microsoft.Xbox.',
    'Microsoft.XboxGaming',
    'Microsoft.XboxIdentityProvider',
    'Microsoft.XboxSpeechToTextOverlay',
    'Microsoft.ZuneMusic',
    'Microsoft.WindowsAlarms',
    'Microsoft.Todos',
    'Microsoft.YourPhone',
    'Microsoft.WindowsSoundRecorder',
    'Microsoft.WindowsCamera',
    'Microsoft.WindowsCalculator',
    'Microsoft.Windows.Photos',
    'Microsoft.MicrosoftStickyNotes',
    'Microsoft.MicrosoftSolitaireCollection',
    'Microsoft.MicrosoftOfficeHub',
    'Microsoft.Bing',
    'Clipchamp.Clipchamp',
    'Microsoft.OutlookForWindows',
    'Microsoft.WindowsNotepad',
    'Microsoft.ScreenSketch',
    'Microsoft.Edge.GameAssist',
    'Microsoft.Copilot'
)
foreach ($filter in $toCleanFilter) {
    Get-AppxPackage -Name "$filter*" | ForEach-Object {
        Write-Host "Removing: $($_.Name)" -ForegroundColor Gray
        Remove-AppxPackage -Package $_.PackageFullName -ErrorAction Stop
    }
}

# Uninstall Teams & OneDrive
$wingetIds = @(
  'Microsoft.Teams',
  'Microsoft.OneDrive'
)

foreach ($pkg in $wingetIds) {
  Write-Host "Ensuring removal of: $pkg" -ForegroundColor Gray
  winget uninstall --id $pkg --silent --accept-source-agreements | Out-Null; $global:LASTEXITCODE = 0
}
'''

[tasks.setup-vm]
description = "Everything to do on a hosted VM"
usage = '''
arg "<password>" help = "The password of the user for autologin"
'''
run = [
  "mise run set-autologin {{ "{{" }} usage.password {{ "}}" }}",
  { task = "disable-lockscreen" },
  { task = "remove-bloatware" },
  { task = "enable-ssh" },
]

[tasks.update-winget]
description = "Update winget packages"
hide = true
run = '''
winget upgrade --all 
'''

[tasks.update-scoop]
description = "Update scoop packages"
hide = true
run = '''
scoop update *
'''

[tasks.update-packages]
description = "Update packages with selected Windows package manager"
hide = true
shell = 'powershell -Command'
run = '''
$manager = [Environment]::GetEnvironmentVariable("MISE_PACKAGE_MANAGER", "User")
if ($null -ne $manager) {
  $manager = $manager.Trim().ToLowerInvariant()
}

switch ($manager) {
  "scoop" { mise run update-scoop }
  default { mise run update-winget }
}
'''

[tasks.install-core-winget]
description = 'Install core CLI packages using winget'
hide = true
shell = 'powershell -Command'
run = '''
$file = Join-Path $env:USERPROFILE ".config/packages/windows/winget/core.winget"
winget configure -f $file --accept-configuration-agreements --disable-interactivity --suppress-initial-details
'''

[tasks.install-gui-winget]
description = 'Install core CLI packages using winget'
hide = true
shell = 'powershell -Command'
run = '''
$file = Join-Path $env:USERPROFILE ".config/packages/windows/winget/gui.winget"
winget configure -f $file --accept-configuration-agreements --disable-interactivity --suppress-initial-details
'''

[tasks.install-core-scoop]
description = 'Install core CLI packages using scoop'
hide = true
shell = 'powershell -Command'
run = '''
$file = Join-Path $env:USERPROFILE ".config/packages/windows/scoop/core.json"
scoop import $file
'''

[tasks.install-gui-scoop]
description = 'Install GUI packages using scoop'
hide = true
shell = 'powershell -Command'
run = '''
$file = Join-Path $env:USERPROFILE ".config/packages/windows/scoop/gui.json"
scoop import $file
'''

[tasks.install-core]
description = 'Install core packages with selected Windows package manager'
shell = 'powershell -Command'
run = '''
$manager = [Environment]::GetEnvironmentVariable("MISE_PACKAGE_MANAGER", "User")
if ($null -ne $manager) {
  $manager = $manager.Trim().ToLowerInvariant()
}

switch ($manager) {
  "scoop" { mise run install-core-scoop }
  default { mise run install-core-winget }
}
'''

[tasks.install-gui]
description = 'Install GUI packages with selected Windows package manager'
shell = 'powershell -Command'
run = '''
$manager = [Environment]::GetEnvironmentVariable("MISE_PACKAGE_MANAGER", "User")
if ($null -ne $manager) {
  $manager = $manager.Trim().ToLowerInvariant()
}

switch ($manager) {
  "scoop" { mise run install-gui-scoop }
  default { mise run install-gui-winget }
}
'''

{{ end }}
[tasks.update-mise]
description = "Update mise en place tools"
hide = true
run = '''
mise upgrade
'''

[tasks.update]
description = "Update all mise & system applications"
run = [
  { task = "update-mise" },
{{ if eq .chezmoi.os "darwin" }}
  { task = "update-homebrew" },
  { task = "update-mas" },
{{ end }}
{{ if eq .chezmoi.os "windows" }}
  { task = "update-packages" },
{{ end }}
]
