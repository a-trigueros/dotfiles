[settings]
experimental = true
env_shell_expand = true

[tools]
argocd = "latest"
atuin = "latest"
bat = "latest"
caddy = "latest"
carapace = "latest"
claude-code = "latest"
delta = "latest"
deno = "latest"
docker-cli = { version = "latest", os = ["macos", "linux"] }
dotnet = "latest"
eza = "latest"
{{- if eq .chezmoi.os "darwin" }}
fnox = "latest"
{{- end }}
fzf = "latest"
helm = "latest"
herdr = "latest"
hugo = "latest"
java = "latest"
jj = "latest"
jjui = "latest"
hunkdiff = "latest"
kubectl = "latest"
lazydocker = "latest"
lazygit = "latest"
lazyjournal = { version = "latest", os = ["macos", "linux"] }
lazyssh = "latest"
mas = { version = "latest", os = "macos" }
neovim = "latest"
node = "lts"
opencode = "latest"
pnpm = "latest"
{{- if eq .chezmoi.os "windows" }}
powershell-core = "latest"
{{- end }}
pi = "latest"
python = "latest"
ripgrep = "latest"
rust = { version = "latest", os = ["macos", "linux"] }
rust-analyzer = { version = "latest", os = ["macos", "linux"] }
sqlite = "latest"
starship = "latest"
television = "latest"
tlrc = "latest"
tmux = "latest"
tree-sitter = "latest"
uv = "latest"
yazi = "latest"
yt-dlp = "latest"
zellij = { version = "latest", os = ["macos", "linux"] }
zoxide = "latest"
"aqua:sharkdp/fd" = "latest"
"cargo:cargo-expand" = { version = "latest", os = ["macos", "linux"] }
"cargo:git-gamble" = { version = "latest", os = ["macos", "linux"] }
"cargo:meli" = { version = "latest", os = ["macos", "linux"] }
"cargo:sheldon" = { version = "latest", os = ["macos", "linux"] }
"npm:@rynfar/meridian" = "latest"
"github:murex/TCR" = "latest"
"github:nushell/nushell" = "latest"
"github:remotemobprogramming/mob" = { version = "latest", os = [
  "macos",
  "linux",
]}
"github:rtk-ai/rtk" = { version = "latest", os = [
  "macos",
  "linux",
]}
"github:joshmedeski/sesh" = { version = "latest", os = [
  "macos",
  "linux",
]}
"pipx:serena-agent" = { version = "latest", postinstall = "serena init", os = [ "macos" ] }

[env]
EDITOR = "nvim"
VISUAL = "nvim"
{{- if ne .chezmoi.os "windows" }}
PAGER = "less -RFX"
{{- end }}
BAT_THEME = "Catppuccin Macchiato"
BAT_STYLE = "numbers,changes,header,grid"
{{- if ne .chezmoi.os "windows" }}
BAT_PAGER = "less -RF"
{{- end }}
MANPAGER = "sh -c 'col -bx | bat -l man -p'"
MANROFFOPT = "-c"
EZA_COLORS = "da=38;5;245:sn=38;5;28:sb=38;5;28:ur=38;5;40:uw=38;5;40:ux=38;5;40:ue=38;5;40:gr=38;5;226:gw=38;5;226:gx=38;5;226:tr=38;5;196:tw=38;5;196:tx=38;5;196"
EZA_ICON_SPACING = "2"
{{ if eq .chezmoi.os "darwin" }}
DOCKER_HOST = 'unix:///Users/$USER/.local/share/containers/podman/machine/podman.sock'
SSH_AUTH_SOCK = '~/Library/Group\ Containers/2BUA8C4S2C.com.1password/t/agent.sock'

VAULT_PATH = "{{ .chezmoi.homeDir }}/vaults/brain/"
_.path = [
  "/opt/homebrew/bin",
  "/opt/homebrew/sbin",
  "/Applications/Visual Studio Code.app/Contents/Resources/app/bin",
]
{{ end }}

DOTNET_CLI_TELEMETRY_OPTOUT=1

[shell_alias]
als = 'atuin script list'
asr = 'atuin script run'
ls = 'eza --color=always --icons=always'
ll = 'eza -lbF --git --icons=always --color=always'
la = 'eza -lbhHigUmuSa --time-style=long-iso --git --color-scale --icons=always --color=always'
lt = 'eza --tree --level=2 --icons=always --color=always'
ltt = 'eza --tree --level=3 --icons=always --color=always'
lttt = 'eza --tree --level=4 --icons=always --color=always'
lg = 'eza -lbhHigUmuSa@ --git --color=always --icons=always'
lm = 'eza -lbhHigUmuSa --sort=modified --color=always --icons=always'
lz = 'eza -lbhHigUmuSa --sort=size --color=always --icons=always'
cd = 'z'
".." = 'cd ..'
"..." = 'cd ../..'
"...." = 'cd ../../..'

