{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "obsidian-brain": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "obsidian-brain@latest",
        "server"
      ]
    },
    "serena": {
      "type": "local",
      "command": [
        "serena",
        "start-mcp-server",
        "--project-from-cwd"
      ]
    },
    "web-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@zhafron/mcp-web-search"
      ]
    }
  },
  "plugin": []
}
