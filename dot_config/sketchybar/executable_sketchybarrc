#!/bin/bash

# ╔══════════════════════════════════════════════════════════╗
# ║           sketchybar — Catppuccin Macchiato              ║
# ║   Widgets : workspaces · front_app · clock · wifi        ║
# ║             now_playing · amphetamine                     ║
# ╚══════════════════════════════════════════════════════════╝

PLUGIN_DIR="$CONFIG_DIR/plugins"
source "$CONFIG_DIR/colors.sh"
source "$CONFIG_DIR/icons.sh"

sketchybar --add event aerospace_workspace_change

# ─── Fonte principale ─────────────────────────────────────
FONT="Hack Nerd Font:style=Regular"
FONT_BOLD="Hack Nerd Font:style=Bold"
ICON_FONT="Hack Nerd Font:style=Regular"

# ═══════════════════════════════════════════════════════════
# BAR — Apparence globale
# ═══════════════════════════════════════════════════════════
sketchybar --bar \
  display=main \
  position=top \
  height=36 \
  margin=0 \
  y_offset=0 \
  corner_radius=0 \
  border_width=0 \
  border_color=$BAR_BORDER \
  blur_radius=20 \
  color=$BASE \
  shadow=off \
  padding_left=8 \
  padding_right=8 \
  notch_width=0 \
  topmost=window

# ═══════════════════════════════════════════════════════════
# DEFAULTS — Valeurs par défaut pour tous les items
# ═══════════════════════════════════════════════════════════
sketchybar --default \
  updates=when_shown \
  icon.font="$ICON_FONT:18.0" \
  icon.color=$SUBTEXT1 \
  icon.padding_left=6 \
  icon.padding_right=3 \
  label.font="$FONT:14.0" \
  label.color=$TEXT \
  label.padding_left=3 \
  label.padding_right=6 \
  background.color=$TRANSPARENT \
  background.corner_radius=8 \
  background.height=28 \
  background.border_width=0 \
  background.border_color=$SURFACE1 \
  padding_left=3 \
  padding_right=3

# ═══════════════════════════════════════════════════════════
# ESPACE GAUCHE — Workspaces AeroSpace
# ═══════════════════════════════════════════════════════════

# ─── Meteo ─────────────────────────────────────────────────
sketchybar --add item weather left \
  --set weather \
  icon="󰖔" \
  icon.color=$SKY \
  icon.font="$ICON_FONT:16.0" \
  label.drawing=on \
  label.font="$FONT:12.0" \
  label.color=$SUBTEXT1 \
  background.color=$TRANSPARENT \
  update_freq=300 \
  script="$PLUGIN_DIR/weather.sh" \
  --subscribe weather system_woke

# Les workspaces sont entièrement gérés par le plugin aerospace.sh
# (création + style + sync)
"$PLUGIN_DIR/aerospace.sh" poll

# Séparateur gauche
sketchybar --add item separator_left left \
  --set separator_left \
  icon="" \
  icon.color=$SURFACE1 \
  icon.font="$ICON_FONT:12.0" \
  label.drawing=off \
  padding_left=4 \
  padding_right=4

# ─── App active ────────────────────────────────────────────
sketchybar --add item front_app left \
  --set front_app \
  icon.font="$ICON_FONT:15.0" \
  icon.color=$MAUVE \
  icon=$ICON_APP_DEFAULT \
  label.font="$FONT_BOLD:14.0" \
  label.color=$TEXT \
  background.color=$SURFACE0 \
  script="$PLUGIN_DIR/front_app.sh" \
  --subscribe front_app front_app_switched

# ═══════════════════════════════════════════════════════════
# CENTRE — Now Playing
# ═══════════════════════════════════════════════════════════
sketchybar --add item now_playing center \
  --set now_playing \
  icon=$ICON_MUSIC_NOTE \
  icon.color=$PINK \
  icon.font="$ICON_FONT:14.0" \
  label.font="$FONT:12.0" \
  label.color=$SUBTEXT1 \
  label.max_chars=35 \
  background.color=$SURFACE0 \
  padding_left=6 \
  padding_right=6 \
  script="$PLUGIN_DIR/now_playing.sh" \
  --subscribe now_playing media_change

# ═══════════════════════════════════════════════════════════
# ESPACE DROIT — Amphetamine · WiFi · Batterie · Horloge
# ═══════════════════════════════════════════════════════════

# ─── Amphetamine ───────────────────────────────────────────
sketchybar --add item amphetamine right \
  --set amphetamine \
  icon=$ICON_COFFEE_OFF \
  icon.color=$OVERLAY1 \
  icon.font="$ICON_FONT:16.0" \
  label.drawing=off \
  update_freq=5 \
  script="$PLUGIN_DIR/amphetamine.sh" \
  --subscribe amphetamine front_app_switched system_woke

# ─── Séparateur ────────────────────────────────────────────
sketchybar --add item sep_right right \
  --set sep_right \
  icon="·" \
  icon.color=$OVERLAY0 \
  icon.font="$FONT:14.0" \
  label.drawing=off

# ─── WiFi ──────────────────────────────────────────────────
sketchybar --add item wifi right \
  --set wifi \
  icon=$ICON_WIFI_FULL \
  icon.color=$SAPPHIRE \
  icon.font="$ICON_FONT:16.0" \
  label.font="$FONT:12.0" \
  label.color=$SUBTEXT1 \
  script="$PLUGIN_DIR/wifi.sh" \
  --subscribe wifi wifi_change system_woke

# ─── Batterie ──────────────────────────────────────────────
sketchybar --add item battery right \
  --set battery \
  icon="" \
  icon.color=$SUBTEXT1 \
  icon.font="$ICON_FONT:15.0" \
  label.font="$FONT:12.0" \
  label.color=$SUBTEXT1 \
  script="$PLUGIN_DIR/battery.sh" \
  --subscribe battery power_source_change system_woke

# ─── Séparateur ────────────────────────────────────────────
sketchybar --add item sep_right2 right \
  --set sep_right2 \
  icon="·" \
  icon.color=$OVERLAY0 \
  icon.font="$FONT:14.0" \
  label.drawing=off

# ─── Horloge ───────────────────────────────────────────────
sketchybar --add item clock right \
  --set clock \
  icon=$ICON_CLOCK \
  icon.color=$YELLOW \
  icon.font="$ICON_FONT:14.0" \
  label.font="$FONT_BOLD:14.0" \
  label.color=$TEXT \
  update_freq=10 \
  script="$PLUGIN_DIR/clock.sh"

# ─── Workspace sync (event-driven) ─────────────────────────
sketchybar --add item workspace_poller left \
  --set workspace_poller \
  icon=" " \
  icon.color=0x00000000 \
  label.drawing=off \
  background.drawing=off \
  width=0 \
  update_freq=5 \
  script="$PLUGIN_DIR/aerospace.sh poll"

sketchybar --subscribe workspace_poller aerospace_workspace_change front_app_switched

# ═══════════════════════════════════════════════════════════
# FINALISATION
# ═══════════════════════════════════════════════════════════
sketchybar --update
echo "sketchybar chargé ✓"
